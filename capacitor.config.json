{
  "appId": "com.strongstep.app",
  "appName": "StrongStep",
  "webDir": "www",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0c0f",
      "showSpinner": false
    },
    "Geolocation": {
      "permissions": ["location"]
    }
  }
}
